# Optional: GitHub token for Copilot SDK authentication
# If not set, the SDK uses the logged-in Copilot CLI user (recommended)
# GITHUB_TOKEN=ghp_your_token_here

# Discord bot token — create at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Optional: restrict to specific Discord user ID (recommended)
# Find your ID: Discord settings → Advanced → Developer Mode → right-click yourself → Copy ID
DISCORD_OWNER_ID=

# Optional: override AI model (default: gpt-mini → gpt-5-mini, 0x premium)
# Preset names: gpt-mini, haiku, sonnet, flash, gpt5
# Or use a raw Copilot model ID: claude-sonnet-4.6, gpt-5, gemini-3-pro, etc.
# AI_MODEL=gpt-mini

# Optional: override brain data directory (default: auto-detected)
# BRAIN_DATA_DIR=C:\Users\cpuch\Documents\code\stuffleberry\scripture-study\private-brain
