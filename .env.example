# Optional: GitHub token for Copilot SDK authentication
# If not set, the SDK uses the logged-in Copilot CLI user (recommended)
# GITHUB_TOKEN=ghp_your_token_here

# Discord bot token — create at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# Optional: restrict to specific Discord user ID (recommended)
# Find your ID: Discord settings → Advanced → Developer Mode → right-click yourself → Copy ID
DISCORD_OWNER_ID=

# Optional: override AI model (default: gpt-mini → gpt-5-mini, 0x premium)
# Preset names: gpt-mini, haiku, sonnet, flash, gpt5
# Or use a raw Copilot model ID: claude-sonnet-4.6, gpt-5, gemini-3-pro, etc.
# AI_MODEL=gpt-mini

# Optional: override brain data directory (default: ~/.brain-data)
# This is where the SQLite database and vector store live.
# BRAIN_DATA_DIR=~/.brain-data

# Optional: override individual storage paths
# BRAIN_DB_PATH=~/.brain-data/brain.db
# BRAIN_VEC_DIR=~/.brain-data/vec

# Optional: archive export directory (private-brain repo for finished ideas)
# If set, the "archive" API endpoint will write markdown + git commit here.
# BRAIN_ARCHIVE_DIR=C:\Users\cpuch\Documents\code\stuffleberry\scripture-study\private-brain

# --- Embedding ---
# Backend for semantic search embeddings (default: lmstudio)
# Options: lmstudio, ollama, openai, none
# EMBEDDING_BACKEND=lmstudio

# Embedding model name (default: nomic-embed-text)
# EMBEDDING_MODEL=nomic-embed-text

# Ollama URL (only used when EMBEDDING_BACKEND=ollama)
# OLLAMA_URL=http://localhost:11434

# --- Web UI ---
# Enable/disable the built-in web UI (default: true)
# WEB_ENABLED=true

# Web UI port (default: 8445)
# WEB_PORT=8445

# --- Relay ---
# ibeco.me relay connection (optional — brain works standalone)
# IBECOME_URL=wss://ibeco.me/ws/brain
# IBECOME_TOKEN=your_relay_token
